<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    tools:context="com.herohan.uvcapp.activity.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.Usbvideo.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.Usbvideo.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rl_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.serenegiant.widget.AspectRatioTextureView
            android:id="@+id/viewMainPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignWithParentIfMissing="true"
            android:layout_centerInParent="true"
            android:visibility="invisible"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="80dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:textColor="@color/green"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvConnectUSBCameraTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/main_connect_usb_tip"
            android:textColor="@color/white"
            android:textSize="20dp"
            app:layout_constraintStart_toStartOf="@+id/tvFps"
            app:layout_constraintTop_toBottomOf="@+id/tvFps" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/tv_faceid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/shape_input"
            android:hint="faceid"
            android:inputType="number"
            android:textColor="@color/green"
            android:textColorHint="@color/green"
            app:layout_constraintStart_toStartOf="@+id/tvConnectUSBCameraTip"
            app:layout_constraintTop_toBottomOf="@+id/tvConnectUSBCameraTip" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/tv_ft"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/shape_input"
            android:gravity="start"
            android:hint="特征值"
            android:lines="3"
            android:maxLines="3"
            android:textColor="@color/green"
            android:textColorHint="@color/green"
            app:layout_constraintStart_toStartOf="@+id/tv_faceid"
            app:layout_constraintTop_toBottomOf="@+id/tv_faceid" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="同步到本机"
            app:layout_constraintStart_toStartOf="@+id/tv_ft"
            app:layout_constraintTop_toBottomOf="@+id/tv_ft" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvVideoRecordTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:drawableLeft="@drawable/ic_record_red_dot"
                android:drawablePadding="5dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="99:99:99" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabVideo"
                style="@style/MainFloatingActionButton"
                android:layout_above="@id/fabPicture"
                android:layout_alignParentRight="true"
                android:layout_marginEnd="@dimen/fab_margin"
                android:layout_marginBottom="16dp"
                android:visibility="invisible"
                app:srcCompat="@drawable/ic_switch_video" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabPicture"
                style="@style/MainFloatingActionButton"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="@dimen/fab_margin"
                android:layout_marginRight="15dp"
                android:layout_marginBottom="18dp"
                android:visibility="invisible"
                app:srcCompat="@drawable/ic_switch_camera" />

            <Button
                android:id="@+id/button_recog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="开始识别" />

            <Button
                android:id="@+id/button_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="暂停识别" />

            <Button
                android:id="@+id/button_face"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="录入人脸" />

            <Button
                android:id="@+id/button_palm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="录入手掌" />

            <Button
                android:id="@+id/button_del"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="6dp"
                android:text="清空底库" />

            <Button
                android:id="@+id/ota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="0dp"
                android:text="升级测试" />


        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>